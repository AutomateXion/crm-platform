version: '3.9'

services:
  # ─── Databases ────────────────────────────────────────────────
  postgres-core:
    image: postgres:15-alpine
    container_name: crm_postgres_core
    environment:
      POSTGRES_DB: crm_core
      POSTGRES_USER: crm_user
      POSTGRES_PASSWORD: crm_password_2024
    ports:
      - '5432:5432'
    volumes:
      - postgres_core_data:/var/lib/postgresql/data
      - ./infrastructure/docker/init-db.sql:/docker-entrypoint-initdb.d/01-init.sql
      - ./infrastructure/docker/init-phase1.sql:/docker-entrypoint-initdb.d/02-phase1.sql
      - ./infrastructure/docker/init-phase2.sql:/docker-entrypoint-initdb.d/03-phase2.sql
    networks:
      - crm_network
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U crm_user -d crm_core']
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: crm_redis
    ports:
      - '6379:6379'
    volumes:
      - redis_data:/data
    networks:
      - crm_network
    command: redis-server --appendonly yes
    healthcheck:
      test: ['CMD', 'redis-cli', 'ping']
      interval: 10s
      timeout: 5s
      retries: 5

  mongodb:
    image: mongo:6-jammy
    container_name: crm_mongodb
    environment:
      MONGO_INITDB_ROOT_USERNAME: crm_admin
      MONGO_INITDB_ROOT_PASSWORD: crm_mongo_2024
      MONGO_INITDB_DATABASE: crm_audit
    ports:
      - '27017:27017'
    volumes:
      - mongo_data:/data/db
    networks:
      - crm_network
    healthcheck:
      test: ['CMD', 'mongosh', '--eval', 'db.adminCommand("ping")']
      interval: 10s
      timeout: 5s
      retries: 5

  # ─── Core Backend ─────────────────────────────────────────────
  crm-core:
    build:
      context: ./crm-core
      dockerfile: Dockerfile
    container_name: crm_core_api
    environment:
      NODE_ENV: development
      PORT: 3000
      DB_HOST: postgres-core
      DB_PORT: 5432
      DB_NAME: crm_core
      DB_USER: crm_user
      DB_PASS: crm_password_2024
      REDIS_HOST: redis
      REDIS_PORT: 6379
      REDIS_PASSWORD: crm_redis_2024
      MONGO_URI: mongodb://crm_admin:crm_mongo_2024@mongodb:27017/crm_audit?authSource=admin
      JWT_SECRET: crm_jwt_super_secret_2024_change_in_production
      JWT_EXPIRES_IN: 24h
      JWT_REFRESH_EXPIRES_IN: 7d
      BCRYPT_ROUNDS: 10
      FRONTEND_URL: http://localhost:5173
    ports:
      - '3000:3000'
    depends_on:
      postgres-core:
        condition: service_healthy
      redis:
        condition: service_healthy
      mongodb:
        condition: service_healthy
    networks:
      - crm_network
    volumes:
      - ./crm-core:/app
      - /app/node_modules
    command: npm run start:dev

  # ─── Frontend ─────────────────────────────────────────────────
  crm-frontend:
    build:
      context: ./crm-frontend
      dockerfile: Dockerfile
    container_name: crm_frontend
    environment:
      VITE_API_URL: http://localhost:3000
      VITE_APP_NAME: CRM Platform
    ports:
      - '5173:5173'
    depends_on:
      - crm-core
    networks:
      - crm_network
    volumes:
      - ./crm-frontend:/app
      - /app/node_modules

  # ─── Nginx Reverse Proxy ──────────────────────────────────────
  nginx:
    image: nginx:alpine
    container_name: crm_nginx
    ports:
      - '80:80'
      - '443:443'
    volumes:
      - ./infrastructure/nginx/nginx.conf:/etc/nginx/nginx.conf
      - ./infrastructure/nginx/certs:/etc/nginx/certs
    depends_on:
      - crm-core
      - crm-frontend
    networks:
      - crm_network

volumes:
  postgres_core_data:
  redis_data:
  mongo_data:
  pm_uploads:

networks:
  crm_network:
    driver: bridge

  pm-service:
    build:
      context: ./pm-service
      dockerfile: Dockerfile
    container_name: crm_pm_api
    environment:
      NODE_ENV: development
      PORT: 3001
      DB_HOST: postgres-core
      DB_PORT: 5432
      DB_NAME: crm_core
      DB_USER: crm_user
      DB_PASS: crm_password_2024
      JWT_SECRET: crm_jwt_super_secret_2024_change_in_production
    ports:
      - '3001:3001'
    depends_on:
      postgres-core:
        condition: service_healthy
    networks:
      - crm_network
    volumes:
      - ./pm-service:/app
      - /app/node_modules
      - pm_uploads:/app/uploads
    command: npm run start:dev

  pm-service:
    build:
      context: ./pm-service
      dockerfile: Dockerfile
    container_name: crm_pm_api
    environment:
      NODE_ENV: development
      PORT: 3001
      DB_HOST: postgres-core
      DB_PORT: 5432
      DB_NAME: crm_core
      DB_USER: crm_user
      DB_PASS: crm_password_2024
      JWT_SECRET: crm_jwt_super_secret_2024_change_in_production
    ports:
      - '3001:3001'
    depends_on:
      postgres-core:
        condition: service_healthy
    networks:
      - crm_network
    volumes:
      - ./pm-service:/app
      - /app/node_modules
      - pm_uploads:/app/uploads
    command: npm run start:dev
