# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_core
DB_USER=crm_user
DB_PASS=crm_password_2024
DB_SSL=false

# ─── MongoDB (Audit Trail) ────────────────────────────────────────────────────
MONGO_URI=mongodb://crm_admin:crm_mongo_2024@localhost:27017/crm_audit?authSource=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=crm_redis_2024

# ─── JWT ──────────────────────────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION — use a long random string (min 64 chars)
JWT_SECRET=crm_jwt_super_secret_2024_change_in_production_use_64_char_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
